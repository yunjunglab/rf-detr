    "inputs": [
        {
            "id": "datasetDir",
            "type": "promptString",
            "description": "\ub370\uc774\ud130\uc14b \uacbd\ub85c (COCO \ub610\ub294 YOLO \ud615\uc2dd)",
            "default": "/path/to/your/dataset"
        },
        {
            "id": "cocoDatasetDir",
            "type": "promptString",
            "description": "COCO keypoint \ub370\uc774\ud130\uc14b \ub8e8\ud2b8 \uacbd\ub85c (train2017/, val2017/, annotations/ \ud3ec\ud568)",
            "default": "/work/yjkim/Project/rf-detr_keypoint_cline/coco_keypoints_dataset"
        },
        {
            "id": "checkpointPath",
            "type": "promptString",
            "description": "\uc774\uc5b4\uc11c \ud6c8\ub828\ud560 \uccb4\ud06c\ud3ec\uc778\ud2b8 \ud30c\uc77c \uacbd\ub85c",
            "default": "output/checkpoint.pth"
        },
        {
            "id": "numKeypoints",
            "type": "promptString",
            "description": "\ud6c8\ub828\ud560 keypoint \uac1c\uc218 (COCO \uae30\ubcf8\uac12: 17)",
            "default": "17"
        },
        {
            "id": "inferenceCheckpoint",
            "type": "promptString",
