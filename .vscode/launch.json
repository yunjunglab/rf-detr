        {
            "name": "RF-DETR Train (Base, COCO/Roboflow)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "args": [
                "--dataset_dir",
                "${input:datasetDir}",
                "--model",
                "base",
                "--epochs",
                "100",
                "--batch_size",
                "4",
                "--output_dir",
                "output",
                "--dataset_format",
                "roboflow"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTORCH_ENABLE_MPS_FALLBACK": "1",
